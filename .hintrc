{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/forms": [
      "default",
      {
        "select-name": "off",
        "label": "off"
      }
    ],
    "axe/name-role-value": "off",
    "disown-opener": "off",
    "css-prefix-order": "off",
    "compat-api/html": "off",
    "compat-api/css": "off",
    "no-inline-styles": "off",
    "meta-viewport": "off"
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not edge <= 147"
  ]
}